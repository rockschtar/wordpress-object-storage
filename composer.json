{
    "name": "rockschtar/wordpress-object-storage",
    "description": "Transients in green",
    "type": "wordpress-muplugin",
    "require": {
        "php": ">=8.4"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Stefan Helmer",
            "email": "rockschtar@gmail.com"
        }
    ],

    "autoload": {
        "psr-4": {
            "Rockschtar\\WordPress\\ObjectStorage\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rockschtar\\WordPress\\ObjectStorage\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "brain/monkey": "^2.2",
        "yoast/phpunit-polyfills": "^4.0",
        "friendsofphp/php-cs-fixer": "^3.95"
    },
    "scripts": {
        "cs:check": "php-cs-fixer check --diff",
        "cs:fix": "php-cs-fixer fix"
    }
}
